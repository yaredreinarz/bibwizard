# --- Ollama (local model server) ---
OLLAMA_HOST=http://localhost:11434
# Default LLM (large language model) used for summaries, chat, and the
# citation-finder entailment step. qwen2.5:7b-instruct is the smallest
# model that handles the prompt's defensive rules reliably; for stronger
# attention to detail (slower) try qwen2.5:14b-instruct.
OLLAMA_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
# Embedding model used for the semantic retrieval step (Chroma vector store).
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# --- Storage (defaults to ~/.bibwizard) ---
# BIBWIZARD_HOME=~/.bibwizard

# --- Literature drop folder (defaults to ./literature in CWD) ---
# LITERATURE_DIR=D:\bibwizard\literature

# --- Embedding / chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5

# --- Behaviour ---
LOG_LEVEL=INFO
AUTO_TAG=true

# --- Careful LLM-driven metadata extraction (slow; overnight-friendly) ---
# When true, every ingest runs the front-matter extractor through the local
# LLM (qwen2.5 / etc) for a careful structured extraction. Adds 30s-3min per
# paper depending on model + hardware, but is much more robust against weird
# layouts than the heuristic scraper. Can also be enabled per-run with the
# --llm-extract flag on `add` / `scan` / `resummarize`.
LLM_EXTRACT_METADATA=false
# Two-pass mode: after the first extraction the LLM is asked to re-review its
# own output against the raw text. Doubles the time, slightly improves quality.
LLM_EXTRACT_VERIFY=true

# --- arXiv ---
ARXIV_API=https://export.arxiv.org/api/query
# Polite delay between arXiv API hits (seconds). arXiv asks for ~3s minimum.
ARXIV_MIN_DELAY=5.0

# --- NASA ADS (optional) ---
# Get a free token at https://ui.adsabs.harvard.edu/user/settings/token
# When set, `bibwizard enrich` and other lookups will also query ADS.
# ADS_API_TOKEN=your-token-here

# --- Unpaywall (open-access PDF lookups, optional) ---
# Unpaywall requires a contact email per request. When set, `bibwizard
# fetch-refs --download` will use Unpaywall to find open-access PDFs for
# references resolved via DOI. When unset, Unpaywall is skipped.
# UNPAYWALL_EMAIL=you@example.edu

# --- Cite-finder reranker ---
# The reranker sits between Chroma retrieval and the LLM entailment step.
# It scores each (claim, candidate-chunk) pair, then per-paper caps and
# reorders so a single noisy paper can't dominate the candidate pool.
RERANKER_ENABLED=true
# "auto" prefers the cross-encoder model when sentence-transformers is
# installed (best quality, requires ~1 GB torch dep); falls back to the
# built-in lexical scorer otherwise. Override to "cross", "lexical", or
# "off" to force a specific mode.
RERANKER_KIND=auto
# Which HuggingFace model to load when reranker_kind=auto/cross.
RERANKER_MODEL=BAAI/bge-reranker-base
# Pull this multiple of pool_size from Chroma so the reranker has enough
# candidates to actually do work. 5x is a good default.
RERANKER_OVERSCAN=5
# After reranking, cap the number of chunks any single paper can
# contribute to the entailment pool. Prevents a noisy or repetitive paper
# from crowding out other candidates.
RERANKER_MAX_PER_PAPER=3

# --- Loading-spinner animation ---
# Which wizard scene to show during long-running operations.
# Options:
#   walking — green ASCII wizard walks between desk and shelf (default)
#   reading — green ASCII wizard parked at desk reading a book
#   pixel   — higher-resolution colored pixel-art wizard (24-bit color terminal recommended)
WIZARD_SCENE=walking
